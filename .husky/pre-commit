#!/usr/bin/env sh

FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Only file types Prettier can parse (avoids ".prettierignore", images, lockfiles, etc.)
MOBILE_FILES=$(
  printf "%s\n" "$FILES" |
    sed -n '/^mobile\//p' |
    grep -E '\.(tsx?|jsx?|json|cjs|mjs|md|ya?ml)$' || true
)

if [ -n "$MOBILE_FILES" ]; then
  echo "📱 Formatting mobile files..."
  OLD_IFS=$IFS
  IFS=$(printf '\n')
  for file in $MOBILE_FILES; do
    [ -z "$file" ] && continue
    npx prettier --write "$file" || {
      IFS=$OLD_IFS
      exit 1
    }
  done
  for file in $MOBILE_FILES; do
    [ -z "$file" ] && continue
    git add "$file"
  done
  IFS=$OLD_IFS
fi
